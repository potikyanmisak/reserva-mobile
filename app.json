{
  "expo": {
    "name": "Reserva",
    "slug": "reserva-premium",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reserva.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDF3E8"
      },
      "package": "com.reserva.app",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": ["expo-image-picker", "@react-native-community/datetimepicker"],
    "extra": {
      "eas": {
        "projectId": "ca1ac8d5-b463-4a88-95f7-74fe676070c4"
      }
    },
    "owner": "mpotikyan"
  }
}
