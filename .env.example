# Copy this file to .env and fill in your values.

# Your server's LAN IP + port (NOT localhost — Expo Go on device can't reach that)
# Mac/Linux: ifconfig | grep "inet "
# Windows:   ipconfig | findstr "IPv4"
EXPO_PUBLIC_API_URL=http://192.168.0.20:3000

# Backend secrets (used by server.ts only, not bundled into the app)
JWT_SECRET=your_jwt_secret_here
RESEND_API_KEY=re_your_resend_key
GEMINI_API_KEY=your_gemini_key
GOOGLE_MAPS_PLATFORM_KEY=your_google_maps_key
